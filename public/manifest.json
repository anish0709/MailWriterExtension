{
  "manifest_version": 3,
  "name": "AI Email Assistant",
  "description": "AI-powered email reply generator",
  "version": "1.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://mail.google.com/*"],
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["*://mail.google.com/*"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "AI Email Assistant"
  }
}